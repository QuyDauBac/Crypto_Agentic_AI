# ── CoinGecko (market data) ──
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_DEMO_KEY=

# ── Google Gemini (AI Agent) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Tin tức: CoinTelegraph RSS — free, KHÔNG cần key/token, không phải cấu hình gì.
#    (CryptoPanic ngừng free tier 04/2026 nên không dùng nữa; config cũ giữ trong
#    app/core/config.py phòng khi quay lại bản trả phí.)
COINTELEGRAPH_BASE_URL=https://cointelegraph.com

# ── App / Auth ──
JWT_SECRET=
JWT_EXPIRE_MINUTES=60

# ── Database ──
DATABASE_URL=sqlite:///./cryptopilot.db

# ── Scheduler / Jobs (Phase 5) ──
ENABLE_SCHEDULER=true
ALERT_CHECK_INTERVAL_MINUTES=10
PROACTIVE_INTERVAL_HOURS=6
REFRESH_COINS_INTERVAL_HOURS=24

# ── OKX wallet integration (Phase 8) ──
# Tạo 1 lần: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
OKX_BASE_URL=https://www.okx.com
